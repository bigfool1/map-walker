# map-walker 数据库配置示例
# 复制此文件为 .env 即可生效：cp .env.example .env

# 数据库驱动: sqlite | mysql
# MySQL 是生产目标后端；SQLite 保留用于本地开发和测试。
DB_DRIVER=mysql

# MySQL DSN: user:pass@tcp(host:port)/dbname
DB_DSN=root:@tcp(127.0.0.1:3306)/map_walker

# SQLite 默认（不设置环境变量时）：
# DB_DRIVER=sqlite
# DB_DSN=data/map-walker.db

MAP_WALKER_SYNTHETIC_PASSWORD=localtestpwd

# Admin API 访问令牌（不设置则禁用 /admin 路由）
MAP_WALKER_ADMIN_TOKEN=