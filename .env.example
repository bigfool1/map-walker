# map-walker 配置示例
# 部署时复制为 .env：cp .env.example .env

# ===== 数据库 =====
# 驱动: sqlite | mysql（Docker 部署默认 mysql）
DB_DRIVER=mysql

# MySQL DSN（Docker Compose 会自动连 mysql 服务）
DB_DSN=mapwalker:changeme@tcp(mysql:3306)/mapwalkerdb

# 本地 SQLite 开发：
# DB_DRIVER=sqlite
# DB_DSN=data/map-walker.db

# ===== MySQL Docker 密码（仅 Docker Compose 使用） =====
MYSQL_ROOT_PASSWORD=changeme
MYSQL_PASSWORD=changeme

# ===== 合成客户端（可选） =====
MAP_WALKER_SYNTHETIC_PASSWORD=localtestpwd

# ===== Admin API（不设置则禁用 /admin 路由） =====
MAP_WALKER_ADMIN_TOKEN=
